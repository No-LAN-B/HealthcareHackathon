DATABASE_URL=sqlite:///./data/medrelay.db
ANTHROPIC_API_KEY=your-api-key-here
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USER=resend
EMAIL_PASS=your-resend-api-key
# Must be a sender Resend allows (test: onboarding@resend.dev). Not the same as EMAIL_USER.
EMAIL_FROM=MedRelay <onboarding@resend.dev>

BOOKING_NOTIFY_EMAIL=you@example.com
# Link in booking email (patient browser). Use frontend dev server URL.
BOOKING_PUBLIC_BASE_URL=http://localhost:5173
